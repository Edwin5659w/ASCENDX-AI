NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://user:password@host.neon.tech/ascendx?sslmode=require"

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# Incluye la URL de la web (Vite) y Expo
CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# --- NEON POSTGRESQL ---
# 1. Crea proyecto en https://neon.tech
# 2. Copia la connection string y pégala aquí:
# DATABASE_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
# 3. Ejecuta: npx prisma migrate deploy && npm run db:seed
