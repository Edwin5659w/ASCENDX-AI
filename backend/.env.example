NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
# Misma base, host DIRECTO (sin "-pooler"). Cópialo del dashboard Neon → "Connection details" → Direct.
# Si no existe en tu plan, pon la misma cadena que DATABASE_URL (URL directa única).
DIRECT_URL="postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"

JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini

# URL de la app web (enlaces de recuperación de contraseña)
WEB_APP_ORIGIN=http://localhost:5173

# Resend (opcional): si está configurado, se envía el email de recuperación de contraseña
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=onboarding@resend.dev

# Expo Push (opcional): mayor fiabilidad y límites en producción
# EXPO_ACCESS_TOKEN=

# Incluye la URL de la web (Vite) y Expo
CORS_ORIGIN=http://localhost:5173,http://localhost:8081

# --- NEON POSTGRESQL ---
# 1. Crea proyecto en https://neon.tech
# 2. DATABASE_URL: puede ser pooled (-pooler) para la API en producción.
#    DIRECT_URL: debe ser la conexión Direct (sin -pooler) para migraciones.
#    En local, si Prisma da P1001 al pooler, usa la URL Direct en DATABASE_URL y DIRECT_URL (misma cadena).
# 3. npx prisma migrate deploy && npm run db:seed
