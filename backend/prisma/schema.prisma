generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  /** En Neon: si P1001 con host "-pooler", usa aquí la URL "Direct" (sin -pooler) y sslmode=require. */
  url      = env("DATABASE_URL")
}

enum Priority {
  LOW
  MEDIUM
  HIGH
}

enum HabitFrequency {
  DAILY
  WEEKLY
}

enum FinanceType {
  INCOME
  EXPENSE
}

enum AIInsightType {
  MOTIVATION
  WARNING
  DAILY_PLAN
  PROCRASTINATION
  CHAT
}

enum TradeSide {
  BUY
  SELL
}

model User {
  id               String   @id @default(uuid())
  name             String
  email            String   @unique
  password         String
  xp               Int      @default(0)
  level            Int      @default(1)
  onboardingDone   Boolean  @default(false)
  pushToken        String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  goals            Goal[]
  habits           Habit[]
  habitCompletions HabitCompletion[]
  financeRecords   FinanceRecord[]
  aiInsights       AIInsight[]
  refreshTokens    RefreshToken[]
  passwordResetTokens PasswordResetToken[]
  userBadges       UserBadge[]
  tasks            Task[]
  trades           Trade[]
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Badge {
  id         String      @id
  title      String
  subtitle   String
  sortOrder  Int         @default(0)
  userBadges UserBadge[]
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge      Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
}

model Goal {
  id          String    @id @default(uuid())
  title       String
  description String?
  category    String?
  priority    Priority  @default(MEDIUM)
  progress    Int       @default(0)
  deadline    DateTime?
  userId      String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([userId])
}

model Task {
  id          String    @id @default(uuid())
  title       String
  completed   Boolean   @default(false)
  goalId      String?
  userId      String
  dueDate     DateTime?
  streakCount Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal        Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([goalId])
}

model Habit {
  id              String         @id @default(uuid())
  name            String
  frequency       HabitFrequency @default(DAILY)
  streak          Int            @default(0)
  lastCompletedAt DateTime?
  reminderEnabled Boolean        @default(false)
  reminderHour    Int?
  reminderMinute  Int?
  userId          String
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions     HabitCompletion[]

  @@index([userId])
}

model Trade {
  id         String    @id @default(uuid())
  symbol     String
  side       TradeSide
  quantity   Decimal   @db.Decimal(18, 8)
  price      Decimal   @db.Decimal(18, 8)
  pnl        Decimal?  @db.Decimal(12, 2)
  emotionTag String?
  note       String?
  tradedAt   DateTime  @default(now())
  userId     String
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tradedAt])
}

model HabitCompletion {
  id            String   @id @default(uuid())
  habitId       String
  userId        String
  completedDate DateTime @db.Date
  createdAt     DateTime @default(now())
  habit         Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, completedDate])
  @@index([userId])
  @@index([habitId])
}

model FinanceRecord {
  id        String      @id @default(uuid())
  type      FinanceType
  amount    Decimal @db.Decimal(12, 2)
  category  String
  note      String?
  userId    String
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIInsight {
  id        String        @id @default(uuid())
  userId    String
  type      AIInsightType
  message   String
  createdAt DateTime      @default(now())
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
