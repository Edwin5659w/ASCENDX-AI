{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": [
    "validators/**/*",
    "types/**/*",
    "first-steps.ts",
    "ai-prompts.ts",
    "methodologies.ts",
    "finance-helpers.ts",
    "chat-helpers.ts",
    "dashboard-helpers.ts",
    "onboarding-helpers.ts",
    "trading-helpers.ts",
    "plans.ts",
    "weekly-recap.ts",
    "retention.ts",
    "retention-playbook.ts",
    "email-content.ts",
    "ascenso-score.ts",
    "morning-ritual.ts",
    "profile-templates.ts",
    "product-tour.ts",
    "checkout-intent.ts",
    "plan-marketing.ts",
    "currencies.ts",
    "i18n/**/*",
    "pagination.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
